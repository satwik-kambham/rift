# Replace

let agentReplaceDeclaration = "{
    \"type\": \"function\",
    \"function\": {
        \"name\": \"replace\",
        \"description\": \"Replaces text within a file and returns structured JSON. Defaults to a single replacement unless `max_replacements` is set.\",
        \"parameters\": {
            \"type\": \"object\",
            \"properties\": {
                \"path\" : { \"type\": \"string\" },
                \"old_string\": { \"type\": \"string\" },
                \"new_string\": { \"type\": \"string\" },
                \"max_replacements\": { \"type\": \"number\", \"description\": \"Optional. 0 means replace all matches. Defaults to 1.\" }
            },
            \"required\": [\"path\", \"old_string\", \"new_string\"]
        }
    }
}"

fn agentReplace(inputs) {
    let maxReplacements = inputs["max_replacements"]
    if isNull(maxReplacements) {
        return agentReplaceTool(getWorkspaceDir(), inputs["path"], inputs["old_string"], inputs["new_string"])
    }
    return agentReplaceTool(getWorkspaceDir(), inputs["path"], inputs["old_string"], inputs["new_string"], maxReplacements)
}

fn agentReplacePreview(inputs) {
    return "Replace: `" + inputs["path"] + "`"
}

fn agentReplaceOutputPreview(output) {
    let parsed = fromJson(output)
    if typeOf(parsed) != "table" {
        return "Replace:\n" + output
    }
    let status = "ok"
    if !parsed["ok"] { status = "error" }
    let message = parsed["message"]
    let result = "Replace (" + status + ")"
    if !isNull(parsed["error_code"]) { result = result + " [" + parsed["error_code"] + "]" }
    if !isNull(message) and stringLen(message) > 0 { result = result + "\n" + message }
    return result
}

#############

let toolDeclarations = {
    "run_shell_command": agentRunShellCommandDeclaration,
    "find_file": agentFindFileDeclaration,
    "search_workspace": agentSearchWorkspaceDeclaration,
    "read_file": agentReadFileDeclaration,
    "write_file": agentWriteFileDeclaration,
    "replace": agentReplaceDeclaration
}

let toolHandlers = {
    "run_shell_command": agentRunShellCommand,
    "find_file": agentFindFile,
    "search_workspace": agentSearchWorkspace,
    "read_file": agentReadFile,
    "write_file": agentWriteFile,
    "replace": agentReplace
}

let toolPreviews = {
    "run_shell_command": agentRunShellCommandPreview,
    "find_file": agentFindFilePreview,
    "search_workspace": agentSearchWorkspacePreview,
    "read_file": agentReadFilePreview,
    "write_file": agentWriteFilePreview,
    "replace": agentReplacePreview
}

let toolOutputPreviews = {
    "run_shell_command": agentRunShellCommandOutputPreview,
    "find_file": agentFindFileOutputPreview,
    "search_workspace": agentSearchWorkspaceOutputPreview,
    "read_file": agentReadFileOutputPreview,
    "write_file": agentWriteFileOutputPreview,
    "replace": agentReplaceOutputPreview
}

fn getToolDeclarations(tools) {
    let declarations = []
    for toolName in tools {
        let declaration = toolDeclarations[toolName]
        if declaration != null {
            arrayPushBack(declarations, fromJson(declaration))
        }
    }
    return declarations
}

fn runTool(toolName, inputs) {
    let handler = toolHandlers[toolName]
    if handler == null { return "Unknown tool call." }
    return handler(inputs)
}

fn toolPreview(toolName, inputs) {
    let handler = toolPreviews[toolName]
    if handler == null { return "" }
    return handler(inputs)
}

fn toolOutputPreview(toolName, outputs) {
    let handler = toolOutputPreviews[toolName]
    if handler == null { return "" }
    return handler(outputs)
}
