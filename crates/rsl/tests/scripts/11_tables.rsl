# Empty table
let t = {}
assertEqual(arrayLen(tableKeys(t)), 0)

# tableSet and tableGet
tableSet(t, "x", 10)
assertEqual(tableGet(t, "x"), 10)

tableSet(t, "y", 20)
assertEqual(tableGet(t, "y"), 20)

# Bracket access
assertEqual(t["x"], 10)
assertEqual(t["y"], 20)

# Bracket assignment
t["z"] = 30
assertEqual(t["z"], 30)
assertEqual(tableGet(t, "z"), 30)

# Missing key returns null
assert(isNull(tableGet(t, "missing")))

# tableKeys count
assertEqual(arrayLen(tableKeys(t)), 3)

# Overwrite existing key
tableSet(t, "x", 100)
assertEqual(t["x"], 100)

t["y"] = 200
assertEqual(t["y"], 200)

# Multiple value types
let multi = {"num": 42, "str": "hello", "bool": true, "nil": null}
assertEqual(multi["num"], 42)
assertEqual(multi["str"], "hello")
assertEqual(multi["bool"], true)
assert(isNull(multi["nil"]))

# Nested tables
let outer = {"inner": {"value": 99}}
assertEqual(tableGet(tableGet(outer, "inner"), "value"), 99)

# Table with function value
fn greetName(self) {
    return "hello " + tableGet(self, "name")
}
let obj = {"name": "rift", "greet": greetName}
let greetFn = tableGet(obj, "greet")
assertEqual(greetFn(obj), "hello rift")

# Table used as accumulator
let counts = {}
let words = ["a", "b", "a", "c", "b", "a"]
let i = 0
loop {
    if i >= arrayLen(words) {
        break
    }
    let word = words[i]
    let current = tableGet(counts, word)
    if isNull(current) {
        tableSet(counts, word, 1)
    } else {
        tableSet(counts, word, current + 1)
    }
    i = i + 1
}
assertEqual(counts["a"], 3)
assertEqual(counts["b"], 2)
assertEqual(counts["c"], 1)

# Table literals
let litEmpty = {}
assertEqual(arrayLen(tableKeys(litEmpty)), 0)

let litT = {"x": 10, "y": 20}
assertEqual(litT["x"], 10)
assertEqual(litT["y"], 20)
assertEqual(arrayLen(tableKeys(litT)), 2)

# Table literal with expression values
let litExpr = {"sum": 1 + 2, "prod": 3 * 4}
assertEqual(litExpr["sum"], 3)
assertEqual(litExpr["prod"], 12)

# Nested table literals
let litNested = {"inner": {"val": 99}}
assertEqual(tableGet(litNested["inner"], "val"), 99)

# Table literal with mixed value types
let litMixed = {"num": 42, "str": "hello", "bool": true, "nil": null}
assertEqual(litMixed["num"], 42)
assertEqual(litMixed["str"], "hello")
assertEqual(litMixed["bool"], true)
assert(isNull(litMixed["nil"]))

# Table literal works with existing table functions
let litMut = {"a": 1}
tableSet(litMut, "b", 2)
assertEqual(litMut["a"], 1)
assertEqual(litMut["b"], 2)
