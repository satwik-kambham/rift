# Greater than
assert(3 > 2)
assert(!(2 > 3))
assert(!(2 > 2))

# Less than
assert(2 < 3)
assert(!(3 < 2))
assert(!(2 < 2))

# Greater than or equal
assert(3 >= 3)
assert(3 >= 2)
assert(!(2 >= 3))

# Less than or equal
assert(2 <= 2)
assert(2 <= 3)
assert(!(3 <= 2))

# Equality on numbers
assert(1 == 1)
assert(0 == 0)
assert(-1 == -1)
assert(3.14 == 3.14)

# Inequality on numbers
assert(1 != 2)
assert(0 != 1)
assert(-1 != 1)

# Equality on booleans
assert(true == true)
assert(false == false)
assert(true != false)
assert(false != true)

# Equality on strings
assert("abc" == "abc")
assert("" == "")
assert("abc" != "def")
assert("abc" != "")

# Null equality
assert(null == null)
assert(null != 0)
assert(null != "")
assert(null != false)

# Cross-type inequality
assert(1 != "1")
assert(0 != false)
assert("" != null)
assert(0 != null)
