# Concatenation
assertEqual("hello" + " " + "world", "hello world")
assertEqual("" + "a", "a")
assertEqual("a" + "", "a")
assertEqual("" + "", "")

# String length
assertEqual(stringLen(""), 0)
assertEqual(stringLen("hello"), 5)
assertEqual(stringLen("a b"), 3)

# Escape sequences (verify via length)
assertEqual(stringLen("a\nb"), 3)   # newline is 1 char
assertEqual(stringLen("a\tb"), 3)   # tab is 1 char
assertEqual(stringLen("a\\b"), 3)   # backslash is 1 char

# stringContains
assert(stringContains("hello world", "world"))
assert(stringContains("hello world", "hello"))
assert(stringContains("hello", "hello"))
assert(stringContains("hello", ""))
assert(!stringContains("hello", "xyz"))
assert(!stringContains("", "a"))

# stringSplitLines
let lines = stringSplitLines("a\nb\nc")
assertEqual(arrayLen(lines), 3)
assertEqual(arrayGet(lines, 0), "a")
assertEqual(arrayGet(lines, 1), "b")
assertEqual(arrayGet(lines, 2), "c")

let singleLine = stringSplitLines("hello")
assertEqual(arrayLen(singleLine), 1)
assertEqual(arrayGet(singleLine, 0), "hello")

# stringToLower
assertEqual(stringToLower("HELLO"), "hello")
assertEqual(stringToLower("HeLLo"), "hello")
assertEqual(stringToLower("hello"), "hello")
assertEqual(stringToLower(""), "")

# stringWidth (ASCII chars are width 1)
assertEqual(stringWidth("abc"), 3)
assertEqual(stringWidth(""), 0)
assertEqual(stringWidth("hello"), 5)

# stringTruncateWidth
assertEqual(stringTruncateWidth("hello", 3), "hel")
assertEqual(stringTruncateWidth("hello", 10), "hello")
assertEqual(stringTruncateWidth("hello", 5), "hello")
assertEqual(stringTruncateWidth("hello", 0), "")

# toString conversions
assertEqual(toString(42), "42")
assertEqual(toString(true), "true")
assertEqual(toString(false), "false")
assertEqual(toString(null), "null")
assertEqual(toString("hello"), "hello")
