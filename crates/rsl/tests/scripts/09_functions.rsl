# Basic function
fn add(a, b) {
    return a + b
}
assertEqual(add(2, 3), 5)
assertEqual(add(-1, 1), 0)

# Function with string return
fn greet(name) {
    return "hello " + name
}
assertEqual(greet("world"), "hello world")

# No explicit return (implicit null)
fn noop() {
}
assert(isNull(noop()))

# Single parameter
fn double(x) {
    return x * 2
}
assertEqual(double(5), 10)

# Closure capturing outer variable
let base = 100
fn addToBase(n) {
    return base + n
}
assertEqual(addToBase(10), 110)

# Closure sees updated outer value
base = 200
assertEqual(addToBase(10), 210)

# Recursion: factorial
fn factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}
assertEqual(factorial(0), 1)
assertEqual(factorial(1), 1)
assertEqual(factorial(5), 120)

# Recursion: fibonacci
fn fib(n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}
assertEqual(fib(0), 0)
assertEqual(fib(1), 1)
assertEqual(fib(10), 55)

# Nested function calls
assertEqual(add(add(1, 2), add(3, 4)), 10)

# First-class functions: pass as argument
fn apply(f, x) {
    return f(x)
}
assertEqual(apply(double, 7), 14)

# Function as value in variable
let myFunc = add
assertEqual(myFunc(3, 4), 7)

# Factory function (true closure)
fn makeAdder(x) {
    fn adder(y) {
        return x + y
    }
    return adder
}
let add5 = makeAdder(5)
let add10 = makeAdder(10)
assertEqual(add5(3), 8)
assertEqual(add10(3), 13)
assertEqual(add5(0), 5)

# Mutable closure (counter)
fn makeCounter(start) {
    let count = start
    fn increment(step) {
        count = count + step
        return count
    }
    return increment
}
let counter = makeCounter(0)
assertEqual(counter(1), 1)
assertEqual(counter(1), 2)
assertEqual(counter(5), 7)

# Closure toggle
fn makeToggle() {
    let state = false
    fn toggle() {
        state = !state
        return state
    }
    return toggle
}
let toggle = makeToggle()
assertEqual(toggle(), true)
assertEqual(toggle(), false)
assertEqual(toggle(), true)

# Lambda: anonymous function expression
let square = fn(x) { return x * x }
assertEqual(square(4), 16)
assertEqual(square(0), 0)

# Lambda passed as argument
assertEqual(apply(fn(x) { return x * 3 }, 5), 15)

# Immediately invoked lambda
assertEqual(fn(a, b) { return a + b }(3, 7), 10)

# Lambda with closure capture
let multiplier = 10
let scale = fn(x) { return x * multiplier }
assertEqual(scale(5), 50)

# Lambda factory (closure returning lambda)
fn makeMultiplier(factor) {
    return fn(x) { return x * factor }
}
let triple = makeMultiplier(3)
let quadruple = makeMultiplier(4)
assertEqual(triple(5), 15)
assertEqual(quadruple(5), 20)

# Chained call: factory returns function, immediately called
assertEqual(makeMultiplier(6)(7), 42)
