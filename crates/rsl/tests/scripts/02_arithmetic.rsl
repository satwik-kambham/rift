# Addition
assertEqual(1 + 2, 3)
assertEqual(0 + 0, 0)
assertEqual(1.5 + 2.5, 4)
assertEqual(100 + -50, 50)

# Subtraction
assertEqual(10 - 4, 6)
assertEqual(0 - 5, -5)
assertEqual(5 - 5, 0)

# Multiplication
assertEqual(3 * 5, 15)
assertEqual(-3 * -2, 6)
assertEqual(-3 * 2, -6)
assertEqual(0 * 999, 0)
assertEqual(1 * 42, 42)

# Division
assertEqual(10 / 2, 5)
assertEqual(7 / 2, 3.5)
assertEqual(0 / 1, 0)
assertEqual(-6 / 2, -3)

# Modulo
assertEqual(10 % 3, 1)
assertEqual(7 % 7, 0)
assertEqual(5 % 2, 1)
assertEqual(10 % 5, 0)
assertEqual(13 % 4, 1)

# Unary negation
assertEqual(-5 + 10, 5)
assertEqual(-(-3), 3)
assertEqual(-0, 0)

# Floor
assertEqual(floor(3.7), 3)
assertEqual(floor(-1.2), -2)
assertEqual(floor(5), 5)
assertEqual(floor(0), 0)
assertEqual(floor(0.9), 0)
