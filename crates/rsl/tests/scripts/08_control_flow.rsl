# Basic if
let r = 0
if true {
    r = 1
}
assertEqual(r, 1)

# If not taken
let s = 0
if false {
    s = 1
}
assertEqual(s, 0)

# If-else
let t = 0
if false {
    t = 1
} else {
    t = 2
}
assertEqual(t, 2)

# Else-if chain
fn classify(n) {
    if n < 0 {
        return "negative"
    } else if n == 0 {
        return "zero"
    } else {
        return "positive"
    }
}
assertEqual(classify(-5), "negative")
assertEqual(classify(0), "zero")
assertEqual(classify(10), "positive")

# Nested if
let result = "none"
if true {
    if true {
        result = "both"
    }
}
assertEqual(result, "both")

let result2 = "none"
if true {
    if false {
        result2 = "inner"
    }
}
assertEqual(result2, "none")

# Loop with break
let i = 0
loop {
    if i == 5 {
        break
    }
    i = i + 1
}
assertEqual(i, 5)

# Loop accumulator (sum 1..10)
let sum = 0
let n = 1
loop {
    if n > 10 {
        break
    }
    sum = sum + n
    n = n + 1
}
assertEqual(sum, 55)

# Return as early exit
fn earlyReturn(x) {
    if x > 0 {
        return "positive"
    }
    return "not positive"
}
assertEqual(earlyReturn(5), "positive")
assertEqual(earlyReturn(-1), "not positive")
assertEqual(earlyReturn(0), "not positive")

# Return from loop inside function
fn findFirst(limit) {
    let i = 0
    loop {
        if i * i > limit {
            return i
        }
        i = i + 1
    }
}
assertEqual(findFirst(10), 4)
assertEqual(findFirst(0), 1)

# Loop with conditional break
let count = 0
let target = 7
loop {
    count = count + 1
    if count == target {
        break
    }
}
assertEqual(count, 7)

# Basic while loop
let w = 0
while w < 5 {
    w = w + 1
}
assertEqual(w, 5)

# While that never executes
let x = 42
while false {
    x = 0
}
assertEqual(x, 42)

# While with break
let y = 0
while y < 100 {
    if y == 3 {
        break
    }
    y = y + 1
}
assertEqual(y, 3)

# While with return inside function
fn sumUpTo(limit) {
    let total = 0
    let i = 1
    while i <= limit {
        total = total + i
        i = i + 1
    }
    return total
}
assertEqual(sumUpTo(10), 55)
assertEqual(sumUpTo(0), 0)

# Nested while
let a = 0
let product = 0
while a < 3 {
    let b = 0
    while b < 3 {
        product = product + 1
        b = b + 1
    }
    a = a + 1
}
assertEqual(product, 9)

# While creates a fresh scope each iteration (let-declared vars don't persist)
let iter = 0
while iter < 3 {
    assertEqual(inner, null)
    let inner = iter
    iter = iter + 1
}

# Basic for loop
let total = 0
let items = [10, 20, 30]
for x in items {
    total = total + x
}
assertEqual(total, 60)

# For over empty array (no iterations)
let ran = false
for x in [] {
    ran = true
}
assertEqual(ran, false)

# For loop with break
let stopped = 0
for x in [1, 2, 3, 4, 5] {
    if x == 3 {
        break
    }
    stopped = x
}
assertEqual(stopped, 2)

# For loop with return inside function
fn sumArray(arr) {
    let total = 0
    for x in arr {
        total = total + x
    }
    return total
}
assertEqual(sumArray([1, 2, 3, 4]), 10)
assertEqual(sumArray([]), 0)

# For loop iterates over a copy (mutations don't affect iteration)
let src = [1, 2, 3]
let collected = []
for x in src {
    arrayPushBack(collected, x)
    arrayPushBack(src, 99)
}
assertEqual(arrayLen(collected), 3)
assertEqual(collected[0], 1)
assertEqual(collected[1], 2)
assertEqual(collected[2], 3)

# For loop scope isolation (loop var fresh each iteration)
let lastX = 0
for x in [10, 20, 30] {
    lastX = x
}
assertEqual(lastX, 30)

# Nested for loops
let pairs = []
for a in [1, 2] {
    for b in [10, 20] {
        arrayPushBack(pairs, a * 100 + b)
    }
}
assertEqual(arrayLen(pairs), 4)
assertEqual(pairs[0], 110)
assertEqual(pairs[1], 120)
assertEqual(pairs[2], 210)
assertEqual(pairs[3], 220)

# For with range
let rangeSum = 0
for i in range(0, 5, 1) {
    rangeSum = rangeSum + i
}
assertEqual(rangeSum, 10)

# Range with step > 1
let evens = []
for i in range(0, 10, 2) {
    arrayPushBack(evens, i)
}
assertEqual(arrayLen(evens), 5)
assertEqual(evens[0], 0)
assertEqual(evens[4], 8)

# Range with negative step
let desc = []
for i in range(5, 0, -1) {
    arrayPushBack(desc, i)
}
assertEqual(arrayLen(desc), 5)
assertEqual(desc[0], 5)
assertEqual(desc[4], 1)

# Range that doesn't evenly divide
let partial = []
for i in range(0, 10, 3) {
    arrayPushBack(partial, i)
}
assertEqual(arrayLen(partial), 4)
assertEqual(partial[0], 0)
assertEqual(partial[1], 3)
assertEqual(partial[2], 6)
assertEqual(partial[3], 9)
